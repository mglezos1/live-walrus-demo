# Fastest runbook: docs/SIMPLE-VPS.md
# ---- Backend (copy to .env.production on the server; never commit secrets) ----
NODE_ENV=production
PORT=3000

# Sui / Walrus (testnet)
SUI_NETWORK=testnet
SUI_WALLET_PATH=/root/.sui/sui_config/client.yaml

# On-chain package IDs (your deployed Move contracts)
DATASET_REGISTRY_PACKAGE_ID=
DATASET_REGISTRY_OBJECT_ID=
PROOF_VERIFIER_PACKAGE_ID=
PROOF_VERIFIER_REGISTRY_OBJECT_ID=

# Hex Ed25519 private key (64 hex chars, optional 0x) for txs that sign on-chain
SUI_PRIVATE_KEY=

# Skip Walrus CLI (Render demos only). Omit or set false for real Walrus.
# DEMO_SKIP_WALRUS=false

# Optional: require this value in header x-invite-token for /datasets /capabilities /proofs /verifier
# INVITE_TOKEN=

# Optional: comma-separated browser origins allowed to call the API (CORS). Empty = allow all.
# CORS_ORIGINS=https://your-frontend.vercel.app,https://localhost:5173

# ---- Frontend (Vite; set in Vercel / Render static / .env.local) ----
# VITE_API_URL=https://api.yourdomain.com
# VITE_INVITE_TOKEN=same_as_INVITE_TOKEN_if_you_use_invite_gate
