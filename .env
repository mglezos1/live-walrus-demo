###########################################################
# 🔐 CRYPTOGRAPHY
###########################################################

# AES-256 key (must be exactly 32 bytes)
AES_KEY=12345678901234567890123456789012


###########################################################
# 🧿 SUI BLOCKCHAIN
###########################################################

# Your published Sui package ID
PACKAGE_ID=0x88f4a1df799d21f6da2a61fa3bc7fedd43679969b4b3997f4c517a842244a4e3

# The Move module inside the package
MODULE_NAME=medical_record

# Active Sui address (your wallet)
SUI_ADDRESS=0x26b282894f3c083f05a4ceaafdd5578ac415a731265b760404ca2e2f64737438


###########################################################
# 🗄 WALRUS STORAGE
###########################################################

# Use default walrus client profile
WALRUS_CONTEXT=default


###########################################################
# 🌐 BACKEND SERVER
###########################################################

# Node.js environment
NODE_ENV=development

# Port for Express API
PORT=3000

# Logging
LOG_LEVEL=info

SUI_NETWORK: Sui network (devnet/testnet/mainnet)
SUI_WALLET_PATH: Path to Sui wallet
WALRUS_CLI_PATH: Path to Walrus CLI
CIRCUITS_DIR: Path to Circom circuits directory
ZKEY_DIR: Path to zkey files directory