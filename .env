# Environment Configuration for Walrus MVP ZK Demo

# Node Environment
NODE_ENV=development
PORT=3000

# Sui Configuration
SUI_NETWORK=testnet
SUI_WALLET_PATH=~/.sui/sui_config/client.yaml
# Private key in hex format (64 characters, no 0x prefix)
# To convert from bech32 format, use: sui keytool export --key-identity <address>
# Then convert the exported key to hex format
# Current active address: 0x26b282894f3c083f05a4ceaafdd5578ac415a731265b760404ca2e2f64737438
# Bech32 key: suiprivkey1qrlgwn3vrmm7w0lpjpl66jmdyxsx2fhk559vwqknt943tk3ntjg4v06hk9t
# âœ… Converted to hex format
SUI_PRIVATE_KEY=fe874e2c1ef7e73fe1907fad4b6d21a06526f6a50ac702d3596b15da335c9156

# Move Contract Package IDs (set after deployment)
# Deploy contracts using: cd move/<contract_name> && sui move build && sui client publish
DATASET_REGISTRY_PACKAGE_ID=0x8939b284a3c48c0398b71a2abce2df9bbf3928b1b80f1a1a09b9adedc8da8ded
DATASET_REGISTRY_OBJECT_ID=0xa6dbc579ce3e6e50e4a4cb513804f07d426b0ca16d3b9dcb264e946d9814bb59
PROOF_VERIFIER_PACKAGE_ID=0x31987d757e1fd70467098f3672095886fa7e079989c1c6837cc59e57a4f4e8e0
PROOF_VERIFIER_REGISTRY_OBJECT_ID=0x756e8ac47503dba4940f46bacb7a86de607526fc2091b6f60ee58ace1b04459d
CAPABILITY_REGISTRY_PACKAGE_ID=
CAPABILITY_REGISTRY_OBJECT_ID=
VERIFIER_PACKAGE_ID=0x36a63d1e65025fbe53a26c3186fda8b15e5d8caf160a61dc3e700b83614e017b
VERIFIER_OBJECT_ID=0x60c3954bee23b5caf8bc535c1a79117a9924e9e42ec7ecdd4c6c202d35b73204

# Walrus Configuration
WALRUS_CLI_PATH=/usr/local/bin/walrus

# Circuit Configuration
CIRCUITS_DIR=./circuits
ZKEY_DIR=./circuits
DATA_DIR=./data

# Debug Configuration
DEBUG=false
