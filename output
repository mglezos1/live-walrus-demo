<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Selective Medical ZKP Generator</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">

    <style>
        body {
            background: #f7f9fc;
            padding: 30px;
        }
        .card {
            border-radius: 12px;
            padding: 25px;
        }
        .success-box {
            display: none;
            margin-top: 25px;
        }
    </style>
</head>
<body>

<div class="container" style="max-width: 750px;">

    <h2 class="mb-4 text-center">Selective Medical ZKP Generator</h2>

    <div class="card shadow-sm">

        <form id="zkpForm">

            <label class="form-label">Patient ID</label>
            <input class="form-control" name="patientId" required>

            <label class="form-label mt-3">Name</label>
            <input class="form-control" name="patientName" required>

            <label class="form-label mt-3">Age</label>
            <input class="form-control" name="age" required>

            <label class="form-label mt-3">Gender</label>
            <input class="form-control" name="gender" required>

            <label class="form-label mt-3">Address</label>
            <input class="form-control" name="address" required>

            <label class="form-label mt-3">Heart Rate</label>
            <input class="form-control" name="hr" required>

            <label class="form-label mt-3">Blood Pressure</label>
            <input class="form-control" name="bp" required>

            <label class="form-label mt-3">Symptoms</label>
            <input class="form-control" name="symptoms" required>

            <label class="form-label mt-3">COVID Result (0 = Negative, 1 = Positive)</label>
            <input class="form-control" name="actual_result" required>

            <button class="btn btn-primary w-100 mt-4" type="submit">
                Generate Selective ZKP
            </button>

        </form>

        <!-- SUCCESS BOX -->
        <div id="successBox" class="success-box">
            <div class="alert alert-success">
                ZKP generated successfully!
            </div>

            <a href="verify.html" class="btn btn-success w-100">
                Go to Verification Page
            </a>
        </div>

    </div>
</div>

<script>
document.getElementById("zkpForm").onsubmit = async (e) => {
    e.preventDefault();

    const formData = new FormData(e.target);
    const payload = {};
    formData.forEach((v, k) => payload[k] = v);

    const res = await fetch("http://localhost:3000/selective-zkp", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
    });

    const data = await res.json();

    if (!data.ok) {
        alert("Error generating ZKP");
        return;
    }

    // Save blob IDs so verify.html can download them
    localStorage.setItem("proofBlobId", data.proofBlobId);
    localStorage.setItem("publicBlobId", data.publicBlobId);
    localStorage.setItem("inputBlobId", data.inputBlobId);

    // Save public signals
    localStorage.setItem("publicSignals", JSON.stringify(data.publicSignals));

    // Show success section
    document.getElementById("successBox").style.display = "block";
};
</script>

</body>
</html>
